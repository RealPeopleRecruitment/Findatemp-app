# --- Database (Vercel Postgres — auto-filled when you connect the Storage tab in Vercel) ---
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=

# --- File storage (Vercel Blob — auto-filled when you connect Blob storage in Vercel) ---
BLOB_READ_WRITE_TOKEN=

# --- Email (Resend — https://resend.com, free tier is plenty to start) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=notifications@findatemp.ie
ADMIN_NOTIFICATION_EMAIL=gerard@findatemp.ie

# --- Admin panel login (choose your own values) ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
